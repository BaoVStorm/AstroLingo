<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        tools:ignore="MissingConstraints">

        <ImageView
            android:id="@+id/backIcon"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/back_press_color_purple"
            android:layout_marginStart="15dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/format_textView_header" />

        <TextView
            android:id="@+id/format_textView_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tra từ vựng"
            android:fontFamily="@font/afacad_bold"
            android:textSize="20sp"
            android:textColor="@color/main_color_purple"
            android:gravity="center"
            android:paddingVertical="13dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/btn_translate"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginEnd="15dp"
            android:src="@drawable/icon_vocab_search"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/format_textView_header" />

        <View
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:background="@color/button_field_hover"
            app:layout_constraintTop_toBottomOf="@id/format_textView_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Ô nhập văn bản -->
    <ScrollView
        android:id="@+id/scrollView_input"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/constraintLayout2"
        app:layout_constraintBottom_toTopOf="@id/scrollView_translating">

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập từ hoặc văn bản"
            android:font="@font/afacad_regular"
            android:textSize="20sp"
            android:gravity="top"
            android:padding="16dp"
            android:textColorHint="@color/dark_grey"
            android:inputType="textMultiLine"
            android:singleLine="false"
            android:scrollbars="vertical"
            android:maxLines="10" />
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/grey"
        app:layout_constraintTop_toBottomOf="@id/scrollView_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Đang dịch -->
    <ScrollView
        android:id="@+id/scrollView_translating"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/scrollView_input"
        app:layout_constraintBottom_toTopOf="@id/language_and_nav_container"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đang dịch"
            android:textSize="20sp"
            android:gravity="top"
            android:padding="16dp"
            android:textColor="@color/main_color"/>
    </ScrollView>

    <!-- Layout cố định "language_switch + nav_button_group" -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/language_and_nav_container"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#80A33EB4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Thanh chọn ngôn ngữ -->
        <LinearLayout
            android:id="@+id/language_switch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btn_lang_from"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Anh"
                android:font="@font/afacad_regular"
                android:textSize="18sp"
                android:padding="15dp"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/btn_swap"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/icon_switch"
                android:padding="8dp" />

            <Button
                android:id="@+id/btn_lang_to"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Việt"
                android:font="@font/afacad_regular"
                android:textSize="18sp"
                android:padding="15dp"
                android:backgroundTint="@android:color/white"
                android:textColor="@color/black"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_button_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@id/language_switch"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Nút "Từ đã tra" -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/btn_history"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/icon_test"
                    app:tint="@color/loginRegister_button_color"
                    android:background="@drawable/rounded_white"
                    android:padding="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Từ đã tra"
                    android:font="@font/afacad_regular"
                    android:textSize="15sp"
                    android:textColor="@color/black" />
            </LinearLayout>

            <!-- Nút micro -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/btn_microphone"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/icon_microphone"
                    android:background="@drawable/rounded_button"
                    android:padding="15dp" />
            </LinearLayout>

            <!-- Nút "Từ đã đánh dấu" -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/btn_saved"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/icon_setting_danhgia5sao"
                    app:tint="@color/loginRegister_button_color"
                    android:background="@drawable/rounded_white"
                    android:padding="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Từ đã đánh dấu"
                    android:font="@font/afacad_regular"
                    android:textSize="15sp"
                    android:textColor="@color/black" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

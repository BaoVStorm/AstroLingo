<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"
    card_view:cardElevation="10dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardBackgroundColor="@color/loading"
    card_view:contentPadding="0dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_search_input_tudatra"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/btn_audio"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/icon_audio" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/word_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancellation"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/word_pronounce"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/ˌkæn.səlˈeɪ.ʃən/"
                android:textColor="#666"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/word_meaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(n): sự bãi bỏ, hủy bỏ"
                android:textColor="#333"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- ConstraintLayout to align the favorite_date and btn_favorite -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent">

            <!-- TextView for favorite_date -->
            <TextView
                android:id="@+id/favorite_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9/5/2025"
                android:textSize="15sp"
                app:layout_constraintBottom_toBottomOf="@id/word_text"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/word_text"
                app:layout_constraintTop_toTopOf="@id/word_text"
                tools:ignore="NotSibling" /> <!-- Added top constraint -->

            <!-- ImageView for btn_favorite -->
            <ImageView
                android:id="@+id/btn_favorite"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/icon_star_notselected"
                app:layout_constraintTop_toBottomOf="@id/favorite_date"
                app:layout_constraintStart_toStartOf="@id/favorite_date"
                app:layout_constraintEnd_toEndOf="@id/favorite_date"
                android:layout_marginTop="20dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

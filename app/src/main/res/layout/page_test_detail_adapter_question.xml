<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"

    android:background="@drawable/rounded_test_question"
    android:elevation="5dp"

    android:layout_margin="15dp"
    >

    <TextView
        android:id="@+id/txt_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_test_question_header"
        android:padding="10dp"

        android:text="asdfasdfadsfasdfasdfasdfsadfasdfasdfadsasdasdasdasdasdasdasdasa"
        android:fontFamily="@font/afacad_medium"
        android:textSize="18sp"

        tools:ignore="MissingConstraints" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="10dp"
        android:paddingVertical="18dp"
        android:orientation="vertical"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_question">

        <TextView
            android:id="@+id/answer1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"

            android:text="A. answer A"
            android:fontFamily="@font/afacad_medium"
            android:textSize="16sp"

            android:layout_weight="1"
            />
        <TextView
            android:id="@+id/answer2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"

            android:text="B. answer B"
            android:fontFamily="@font/afacad_medium"
            android:textSize="16sp"

            android:layout_weight="1"
            />
        <TextView
            android:id="@+id/answer3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"

            android:text="C. answer C"
            android:fontFamily="@font/afacad_medium"
            android:textSize="16sp"

            android:layout_weight="1"
            />
        <TextView
            android:id="@+id/answer4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:text="D. answer D"
            android:fontFamily="@font/afacad_medium"
            android:textSize="16sp"

            android:layout_weight="1"
            />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>